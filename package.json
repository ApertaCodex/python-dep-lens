{
  "name": "python-dep-lens",
  "displayName": "Python Dependency Lens",
  "description": "Shows latest PyPI versions inline next to dependencies in pyproject.toml and provides one-click upgrade buttons using uv or pip",
  "version": "2.0.0",
  "publisher": "apertacodex",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/apertacodex/python-dep-lens.git"
  },
  "bugs": {
    "url": "https://github.com/apertacodex/python-dep-lens/issues"
  },
  "homepage": "https://github.com/apertacodex/python-dep-lens#readme",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Other"
  ],
  "keywords": [
    "python",
    "pyproject",
    "toml",
    "dependencies",
    "uv",
    "pip",
    "version",
    "upgrade",
    "pypi",
    "unused",
    "imports"
  ],
  "icon": "images/icon.png",
  "main": "./out/extension.js",
  "activationEvents": [
    "onStartupFinished",
    "workspaceContains:**/pyproject.toml",
    "onLanguage:toml"
  ],
  "contributes": {
    "languages": [
      {
        "id": "toml",
        "filenames": [
          "pyproject.toml"
        ]
      }
    ],
    "commands": [
      {
        "command": "pythonDepLens.refreshVersions",
        "title": "Refresh Dependency Versions",
        "category": "Python Dep Lens",
        "icon": "$(refresh)"
      },
      {
        "command": "pythonDepLens.upgradeDependency",
        "title": "Upgrade Dependency",
        "category": "Python Dep Lens",
        "icon": "$(arrow-up)"
      },
      {
        "command": "pythonDepLens.upgradeAllDependencies",
        "title": "Upgrade All Dependencies",
        "category": "Python Dep Lens",
        "icon": "$(cloud-download)"
      },
      {
        "command": "pythonDepLens.clearCache",
        "title": "Clear Version Cache",
        "category": "Python Dep Lens",
        "icon": "$(trash)"
      },
      {
        "command": "pythonDepLens.showDependencyInfo",
        "title": "Show Dependency Info",
        "category": "Python Dep Lens",
        "icon": "$(info)"
      },
      {
        "command": "pythonDepLens.scanUsage",
        "title": "Scan for Unused Dependencies",
        "category": "Python Dep Lens",
        "icon": "$(search)"
      },
      {
        "command": "pythonDepLens.removeDependency",
        "title": "Remove Dependency",
        "category": "Python Dep Lens",
        "icon": "$(trash)"
      }
    ],
    "keybindings": [
      {
        "command": "pythonDepLens.refreshVersions",
        "key": "ctrl+alt+shift+r",
        "mac": "cmd+alt+shift+r",
        "when": "resourceFilename == pyproject.toml"
      },
      {
        "command": "pythonDepLens.scanUsage",
        "key": "ctrl+alt+shift+u",
        "mac": "cmd+alt+shift+u",
        "when": "resourceFilename == pyproject.toml"
      }
    ],
    "configuration": {
      "title": "Python Dependency Lens",
      "properties": {
        "pythonDepLens.packageManager": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "uv",
            "pip"
          ],
          "enumDescriptions": [
            "Auto-detect: prefers uv if available, falls back to pip",
            "Always use uv for upgrades",
            "Always use pip for upgrades"
          ],
          "description": "Package manager to use for upgrading dependencies"
        },
        "pythonDepLens.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable inline version hints"
        },
        "pythonDepLens.cacheTTLMinutes": {
          "type": "number",
          "default": 30,
          "minimum": 1,
          "maximum": 1440,
          "description": "How long to cache PyPI version lookups (in minutes)"
        },
        "pythonDepLens.showUpgradeCodeLens": {
          "type": "boolean",
          "default": true,
          "description": "Show upgrade code lens buttons inline"
        },
        "pythonDepLens.showStatusBarItem": {
          "type": "boolean",
          "default": true,
          "description": "Show dependency status in the status bar"
        },
        "pythonDepLens.decorationStyle": {
          "type": "string",
          "default": "both",
          "enum": [
            "inline",
            "codelens",
            "both"
          ],
          "enumDescriptions": [
            "Show latest version as inline decoration only",
            "Show upgrade button as CodeLens only",
            "Show both inline decoration and CodeLens"
          ],
          "description": "How to display version information"
        },
        "pythonDepLens.pypiRegistryUrl": {
          "type": "string",
          "default": "https://pypi.org/pypi",
          "description": "Custom PyPI registry URL (for private registries)"
        },
        "pythonDepLens.concurrentRequests": {
          "type": "number",
          "default": 8,
          "minimum": 1,
          "maximum": 20,
          "description": "Maximum number of concurrent PyPI API requests"
        },
        "pythonDepLens.detectUnusedDependencies": {
          "type": "boolean",
          "default": true,
          "description": "Scan Python source files to detect potentially unused dependencies. Packages used as CLI tools or plugins are excluded from detection."
        }
      }
    },
    "menus": {
      "editor/title": [
        {
          "command": "pythonDepLens.refreshVersions",
          "when": "resourceFilename == pyproject.toml",
          "group": "navigation"
        },
        {
          "command": "pythonDepLens.upgradeAllDependencies",
          "when": "resourceFilename == pyproject.toml",
          "group": "navigation"
        },
        {
          "command": "pythonDepLens.scanUsage",
          "when": "resourceFilename == pyproject.toml",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "pythonDepLens.upgradeDependency",
          "when": "resourceFilename == pyproject.toml",
          "group": "pythonDepLens@1"
        },
        {
          "command": "pythonDepLens.refreshVersions",
          "when": "resourceFilename == pyproject.toml",
          "group": "pythonDepLens@2"
        },
        {
          "command": "pythonDepLens.scanUsage",
          "when": "resourceFilename == pyproject.toml",
          "group": "pythonDepLens@3"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.9.1",
    "ovsx": "^0.10.11",
    "typescript": "^6.0.3"
  }
}
